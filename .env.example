# Claude API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Secret usado para proteger /api/admin/codes (geração de códigos de acesso)
APP_SECRET=

# Banco de dados — SQLite local (dev) ou Turso (produção)
# Dev:  DATABASE_URL="file:./prisma/dev.db"
# Prod: DATABASE_URL="libsql://seu-banco.turso.io"
DATABASE_URL=

# Token de autenticação Turso (apenas produção)
DATABASE_AUTH_TOKEN=
